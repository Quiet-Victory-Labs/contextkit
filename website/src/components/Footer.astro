        </a>
        <a href="https://www.npmjs.com/org/runcontext" target="_blank" rel="noopener" aria-label="npm">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-legal">
      &copy; {new Date().getFullYear()} Quiet Victory Labs. All rights reserved.
    </div>
  </div>
</footer>

<style>
  footer {
    flex-direction: column;
    gap: 1.5rem;
  }

  .site-footer {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  .footer-col h4 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-white);
    margin: 0 0 0.75rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-col li {
    margin-bottom: 0.4rem;
  }

  .footer-col a {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--sl-color-accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-top: 1px solid var(--sl-color-gray-5);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-logo {
    font-weight: 700;
    font-size: 1rem;
    color: var(--sl-color-white);
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-social a {
    color: var(--sl-color-gray-3);
    transition: color 0.15s;
    display: flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: var(--sl-color-accent);
  }

  .footer-legal {
    text-align: center;
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    padding: 1rem 0 0.5rem;
  }
</style>
