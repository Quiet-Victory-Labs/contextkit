{
  "name": "@runcontext/mcp",
  "version": "0.3.5",
  "description": "ContextKit MCP server — expose semantic layers and data context to AI agents via Model Context Protocol",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/erickittelson/ContextKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/erickittelson/ContextKit.git",
    "directory": "packages/mcp"
  },
  "bugs": "https://github.com/erickittelson/ContextKit/issues",
  "engines": { "node": ">=18.0.0" },
  "keywords": ["contextkit", "mcp", "model-context-protocol", "ai", "llm", "semantic-layer", "claude", "cursor", "data-catalog", "ai-agents", "metadata-server", "context-protocol", "copilot", "windsurf", "governance"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@runcontext/core": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
