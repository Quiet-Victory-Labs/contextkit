{
  "name": "@runcontext/ui",
  "version": "0.5.0",
  "description": "Onboarding and studio UI for ContextKit",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/erickittelson/ContextKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/erickittelson/ContextKit.git",
    "directory": "packages/ui"
  },
  "bugs": "https://github.com/erickittelson/ContextKit/issues",
  "engines": { "node": ">=18.0.0" },
  "keywords": ["onboarding", "data-product-builder", "wizard"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "static"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@runcontext/core": "workspace:^",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
