{
  "name": "@runcontext/core",
  "version": "0.2.1",
  "description": "Core compiler, linter, and type system for ContextKit",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/erickittelson/ContextKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/erickittelson/ContextKit.git",
    "directory": "packages/core"
  },
  "keywords": ["context", "compiler", "linter", "yaml", "institutional-knowledge"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
