{
  "name": "@runcontext/core",
  "version": "0.5.0",
  "description": "Compiler and linter for AI-ready semantic metadata",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/erickittelson/ContextKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/erickittelson/ContextKit.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/erickittelson/ContextKit/issues",
  "engines": { "node": ">=18.0.0" },
  "keywords": ["semantic-layer", "ai-metadata", "osi", "data-governance", "mcp"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "duckdb": "^1.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "duckdb": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "duckdb": "^1.4.4",
    "pg": "^8.20.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
