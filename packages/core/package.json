{
  "name": "@runcontext/core",
  "version": "0.3.5",
  "description": "ContextKit core — compiler, linter, tier engine, and database introspection for AI-ready semantic layers",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/erickittelson/ContextKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/erickittelson/ContextKit.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/erickittelson/ContextKit/issues",
  "engines": { "node": ">=18.0.0" },
  "keywords": [
    "contextkit",
    "semantic-layer",
    "metadata",
    "compiler",
    "linter",
    "osi",
    "open-semantic-interchange",
    "ai",
    "llm",
    "data-catalog",
    "governance",
    "database-introspection",
    "metadata-management",
    "tier-scoring",
    "bronze-silver-gold",
    "business-rules",
    "guardrails",
    "duckdb",
    "postgres",
    "snowflake",
    "bigquery",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "duckdb": "^1.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "duckdb": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "duckdb": "^1.4.4",
    "pg": "^8.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
