{
  "name": "@runcontext/core",
  "version": "0.6.1",
  "description": "Compiler, linter, and tier engine for AI-ready semantic metadata. 40 lint rules, Bronze/Silver/Gold scoring, and OSI-compliant data product validation.",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/RunContext/runcontext",
  "repository": {
    "type": "git",
    "url": "https://github.com/RunContext/runcontext.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/RunContext/runcontext/issues",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "runcontext",
    "semantic-layer",
    "semantic-plane",
    "ai-metadata",
    "osi",
    "open-semantic-interchange",
    "data-governance",
    "data-catalog",
    "data-product",
    "mcp",
    "model-context-protocol",
    "schema-validation",
    "metadata-compiler",
    "tier-system"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "duckdb": "^1.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "duckdb": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "duckdb": "^1.4.4",
    "pg": "^8.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
