{
  "name": "@runcontext/site",
  "version": "0.3.4",
  "description": "Static documentation site generator for ContextKit",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/erickittelson/ContextKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/erickittelson/ContextKit.git",
    "directory": "packages/site"
  },
  "keywords": ["contextkit", "site-generator", "documentation", "ejs"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@runcontext/core": "workspace:^",
    "ejs": "^3.1.10",
    "minisearch": "^7.1.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
