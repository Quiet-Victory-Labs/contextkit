{
  "name": "@runcontext/site",
  "version": "0.5.0",
  "description": "Documentation site generator for semantic planes",
  "license": "MIT",
  "author": "Eric Kittelson",
  "homepage": "https://github.com/Quiet-Victory-Labs/contextkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/Quiet-Victory-Labs/contextkit.git",
    "directory": "packages/site"
  },
  "bugs": "https://github.com/Quiet-Victory-Labs/contextkit/issues",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["docs-generator", "data-catalog", "semantic-layer"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "astro"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@runcontext/core": "workspace:^",
    "astro": "^5.18.0",
    "ejs": "^3.1.10",
    "minisearch": "^7.1.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
